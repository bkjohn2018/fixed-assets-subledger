            "source": {
              "type": "m",
              "expression": "let Source = #table(type table [ASSET_ID = Int64.Type, BOOK_TYPE_CODE = type text, PERIOD_COUNTER = Int64.Type, PERIOD_NAME = type text, DEPRN_AMOUNT = type number, DEPRN_BONUS = type number, DEPRN_CATCHUP = type number, DEPRN_YTD = type number, DEPRN_ITD = type number], {}) in Source"
            }
          }
        ]
      },
      {
        "name": "F_Asset_Balance_Period",
        "columns": [
          { "name": "ASSET_ID", "dataType": "Int64", "summarizeBy": "none" },
          { "name": "BOOK_TYPE_CODE", "dataType": "String", "summarizeBy": "none" },
          { "name": "PERIOD_COUNTER", "dataType": "Int64", "summarizeBy": "none" },
          { "name": "PERIOD_NAME", "dataType": "String", "summarizeBy": "none" },
          { "name": "COST_BEG", "dataType": "Decimal", "summarizeBy": "sum" },
          { "name": "ADDITIONS", "dataType": "Decimal", "summarizeBy": "sum" },
          { "name": "ADJUSTMENTS", "dataType": "Decimal", "summarizeBy": "sum" },
          { "name": "TRANSFERS_NET", "dataType": "Decimal", "summarizeBy": "sum" },
