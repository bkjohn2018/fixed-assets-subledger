        ],
        "partitions": [
          {
            "name": "F_Asset_Balance_Period",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = #table(type table [ASSET_ID = Int64.Type, BOOK_TYPE_CODE = type text, PERIOD_COUNTER = Int64.Type, PERIOD_NAME = type text, COST_BEG = type number, ADDITIONS = type number, ADJUSTMENTS = type number, TRANSFERS_NET = type number, RETIREMENTS_COST = type number, DEPRN_PERIOD = type number, DEPRN_YTD = type number, DEPRN_ITD = type number, NBV_END = type number, UNITS = type number], {}) in Source"
            }
